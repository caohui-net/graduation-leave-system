.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: white;
  padding: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.content {
  padding: 20rpx;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.field {
  display: flex;
  margin-bottom: 16rpx;
}

.label {
  font-size: 28rpx;
  color: #999;
  width: 160rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.status-pending_dorm_manager, .status-pending_counselor {
  color: #fa8c16;
}

.status-approved {
  color: #52c41a;
}

.status-rejected {
  color: #ff4d4f;
}

.approval-item {
  position: relative;
  padding-left: 60rpx;
  margin-bottom: 40rpx;
}

.approval-item::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 32rpx;
  bottom: -40rpx;
  width: 2rpx;
  background: #e8e8e8;
}

.approval-item:last-child::before {
  display: none;
}

.approval-item::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: white;
  border: 4rpx solid #1890ff;
}

.approval-item[data-decision="pending"]::after {
  border-color: #fa8c16;
  background: #fff7e6;
}

.approval-item[data-decision="approved"]::after {
  border-color: #52c41a;
  background: #52c41a;
}

.approval-item[data-decision="rejected"]::after {
  border-color: #ff4d4f;
  background: #ff4d4f;
}

.approval-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.step {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.decision {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.decision-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.decision-approved {
  background: #f6ffed;
  color: #52c41a;
}

.decision-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.approval-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.approver, .comment {
  font-size: 26rpx;
  color: #666;
}

.approver {
  font-weight: 500;
}

.actions {
  padding: 20rpx;
}

.comment-section {
  background: white;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.comment-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.comment-section .char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
}

.approve {
  background: #52c41a;
  color: white;
}

.reject {
  background: #ff4d4f;
  color: white;
}

.loading, .error {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.error button {
  margin-top: 20rpx;
  background: #1890ff;
  color: white;
}

/* Attachment styles */
.attachment-error {
  padding: 24rpx;
  background: #fff1f0;
  border-radius: 8rpx;
  color: #ff4d4f;
  font-size: 28rpx;
  text-align: center;
}

.empty-attachments {
  padding: 60rpx 24rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.attachment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.attachment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 8rpx;
}

.attachment-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-right: 20rpx;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.file-size {
  font-size: 24rpx;
  color: #999;
}

.attachment-actions {
  display: flex;
  gap: 12rpx;
}

.btn-small {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border: none;
  border-radius: 6rpx;
  background: white;
}

.btn-small.download {
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.btn-small.delete {
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.btn-upload {
  width: 100%;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #1890ff;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}
