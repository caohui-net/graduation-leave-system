.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20px;
}

/* 用户信息卡片 */
.user-info-card {
  background-color: #ffffff;
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 16px;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 10px 0;
}

.info-label {
  font-size: 14px;
  color: #666666;
  width: 80px;
}

.info-value {
  font-size: 14px;
  color: #333333;
  flex: 1;
}

/* 表单卡片 */
.form-card {
  background-color: #ffffff;
  border-radius: 8px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.field {
  margin-bottom: 20px;
}

.label {
  display: block;
  font-size: 14px;
  color: #333333;
  margin-bottom: 8px;
  font-weight: 500;
}

.textarea {
  width: 100%;
  min-height: 120px;
  padding: 12px;
  border: 1px solid #d9d9d9;
  border-radius: 4px;
  font-size: 14px;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 12px;
  color: #999999;
  margin-top: 4px;
}

.picker {
  padding: 12px;
  border: 1px solid #d9d9d9;
  border-radius: 4px;
  font-size: 14px;
  color: #333333;
}

.submit-btn {
  width: 100%;
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 4px;
  padding: 12px;
  font-size: 16px;
  margin-top: 20px;
}

.submit-btn[disabled] {
  background-color: #d9d9d9;
  color: #999999;
}

.error {
  margin-top: 12px;
  padding: 12px;
  background-color: #fff2f0;
  border: 1px solid #ffccc7;
  border-radius: 4px;
  color: #ff4d4f;
  font-size: 14px;
}
