.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 40rpx;
}

/* 用户信息卡片 */
.user-info-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

/* 表单卡片 */
.form-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.field {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.picker {
  padding: 24rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

.draft-btn {
  width: 100%;
  background-color: #ffffff;
  color: #1890ff;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.draft-btn[disabled] {
  background-color: #f5f5f5;
  color: #d9d9d9;
  border-color: #d9d9d9;
}

.submit-btn {
  width: 100%;
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.submit-btn[disabled] {
  background-color: #d9d9d9;
  color: #999999;
}

.error {
  margin-top: 24rpx;
  padding: 24rpx;
  background-color: #fff2f0;
  border: 2rpx solid #ffccc7;
  border-radius: 8rpx;
  color: #ff4d4f;
  font-size: 28rpx;
}
