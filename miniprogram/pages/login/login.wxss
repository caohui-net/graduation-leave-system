.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
  margin-top: 100rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.form {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: #1890ff;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.login-btn[disabled] {
  background: #d9d9d9;
}

.error {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 20rpx;
  text-align: center;
}
