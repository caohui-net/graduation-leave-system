# 生产环境配置
DB_ENGINE=django.db.backends.postgresql
DB_NAME=graduation_leave
DB_USER=postgres
DB_PASSWORD=${POSTGRES_PASSWORD:-强密码请修改}
DB_HOST=db
DB_PORT=5432

# Django生产配置
SECRET_KEY=${DJANGO_SECRET_KEY:-请生成新密钥}
DEBUG=False
ALLOWED_HOSTS=your-domain.com,218.75.196.218
CORS_ALLOWED_ORIGINS=https://your-domain.com

# 安全设置
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# JWT
JWT_SECRET_KEY=${JWT_SECRET:-请生成新密钥}
JWT_ACCESS_TOKEN_LIFETIME=86400
JWT_REFRESH_TOKEN_LIFETIME=604800

# 青橄榄SSO
QGL_ADMIN_APP_KEY=${QGL_ADMIN_APP_KEY}
QGL_ADMIN_APP_SECRET=${QGL_ADMIN_APP_SECRET}
QGL_MOBILE_TENANT_CODE=${QGL_MOBILE_TENANT_CODE}
QGL_ADMIN_APPID=${QGL_ADMIN_APPID}
QGL_ENV=prod

# 性能优化
CONN_MAX_AGE=600
DB_CONN_MAX_AGE=600
