<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-info-card">
    <view class="card-title">申请人信息</view>
    <view class="info-row">
      <text class="info-label">姓名</text>
      <text class="info-value">{{userName}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">学号</text>
      <text class="info-value">{{userId}}</text>
    </view>
  </view>

  <!-- 申请表单卡片 -->
  <view class="form-card">
    <view class="card-title">离校申请</view>

    <view class="field">
      <text class="label">联系电话 <text class="required">*</text></text>
      <input
        class="input"
        type="number"
        placeholder="请输入手机号码"
        value="{{contactPhone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="field">
      <text class="label">离校原因</text>
      <textarea
        class="textarea"
        placeholder="请输入离校原因（最多500字）"
        value="{{reason}}"
        bindinput="onReasonInput"
        maxlength="500"
        auto-height
      />
      <text class="char-count">{{reason.length}}/500</text>
    </view>

    <view class="field">
      <text class="label">离校日期</text>
      <picker
        mode="date"
        value="{{leaveDate}}"
        start="{{today}}"
        bindchange="onDateChange"
      >
        <view class="picker">{{leaveDate || '请选择日期'}}</view>
      </picker>
    </view>

    <button
      class="draft-btn"
      bindtap="onSaveDraft"
      disabled="{{savingDraft}}"
    >
      {{savingDraft ? '保存中...' : '保存草稿'}}
    </button>

    <button
      class="submit-btn"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交申请'}}
    </button>

    <view class="error" wx:if="{{error}}">{{error}}</view>
  </view>
</view>
