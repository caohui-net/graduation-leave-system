.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: white;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f0f0f0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.user-info {
  font-size: 24rpx;
  color: #999;
}

.list {
  padding: 20rpx;
}

.item {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.student-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.item-body {
  display: flex;
  margin-bottom: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.item-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.empty, .loading, .error {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.error button {
  margin-top: 20rpx;
  background: #1890ff;
  color: white;
}
